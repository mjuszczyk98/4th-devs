NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
# Local development defaults keep mutable server data under apps/server/var.
# For production, point these at absolute paths on persistent storage outside the repo checkout.
# Example production values:
# DATABASE_PATH=/var/lib/wonderlands/05_04_api.sqlite
# FILE_STORAGE_ROOT=/var/lib/wonderlands/files
DATABASE_PATH=./var/05_04_api.sqlite
FILE_STORAGE_ROOT=./var/files
API_BASE_PATH=/api
AUTH_MODE=api_key
AUTH_METHODS=api_key,auth_session
MCP_SECRET_ENCRYPTION_KEY=
MAX_REQUEST_BODY_BYTES=1048576
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Accept,Authorization,Content-Type,Idempotency-Key,X-Request-Id,X-Tenant-Id,X-Trace-Id
CORS_EXPOSE_HEADERS=X-Request-Id,X-Trace-Id,X-Response-Time-Ms,X-Api-Version
CORS_MAX_AGE_SECONDS=600

AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-5.4
AI_REQUEST_TIMEOUT_MS=60000
AI_REQUEST_MAX_RETRIES=2

OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5.4
OPENAI_BASE_URL=
OPENAI_ORGANIZATION=
OPENAI_PROJECT_ID=
OPENAI_SERVICE_TIER=
OPENAI_WEBHOOK_SECRET=

OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.4
OPENROUTER_BASE_URL=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=
OPENROUTER_APP_CATEGORIES=

GOOGLE_API_KEY=
GOOGLE_DEFAULT_MODEL=gemini-2.5-flash
GOOGLE_API_VERSION=
GOOGLE_BASE_URL=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GOOGLE_VERTEXAI=false

# Optional browser sandbox (Kernel).
# Local dev:
#   npm run kernel:up
# Cloud:
#   set KERNEL_ENABLED=true, KERNEL_PROVIDER=cloud, and KERNEL_API_KEY.
KERNEL_ENABLED=true
KERNEL_PROVIDER=local
KERNEL_CDP_URL=http://127.0.0.1:9222
KERNEL_LOCAL_API_URL=http://127.0.0.1:10001
KERNEL_API_URL=https://api.kernel.sh
KERNEL_API_KEY=

# Optional lo runtime for sandbox execution.
# Build the bootstrap first:
#   npm run build --workspace @wonderlands/sandbox-runtime-lo
# Use absolute paths here. Do not use $HOME or $PWD inside .env.
SANDBOX_LO_BINARY=
SANDBOX_LO_BOOTSTRAP_ENTRY=

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=false
LANGFUSE_ENVIRONMENT=development

# Static MCP servers loaded at process startup.
# By default the runtime reads ./.mcp-servers.json from the project root.
# Override the location only if you want a different file path.
# Start from ./.mcp-servers.example.json and copy it to ./.mcp-servers.json.
# The bundled local example mounts files-mcp to ./workspace.
# Add whatever secret env vars your .mcp-servers.json references, for example:
# MY_REMOTE_MCP_TOKEN=
# Generate a stable local key before using OAuth-backed MCP servers:
# openssl rand -hex 32
# MCP_SECRET_ENCRYPTION_KEY=
MCP_SERVERS_FILE=./.mcp-servers.json
